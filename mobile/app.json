{
  "expo": {
    "name": "NammaFlow",
    "slug": "btp-officer",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "btpofficer",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/logo.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.gov.karnataka.btp.officer",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your location is used to confirm you are patrolling your assigned zone.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Background location lets command confirm you remain in your assigned zone for the duration of your patrol.",
        "NSCameraUsageDescription": "The camera is used to capture a GPS-stamped photo for your field report.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true,
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "in.gov.karnataka.btp.officer",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Background location lets command confirm you remain in your assigned zone during patrol.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "web": {
      "favicon": "./assets/logo.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1f78f5cb-d3cc-44a7-a2fa-4431380aea23"
      }
    },
    "owner": "premraichura"
  }
}
