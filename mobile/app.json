{
  "expo": {
    "name": "BTP Patrol",
    "slug": "btp-patrol",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "btppatrol",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.btp.patrol",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "BTP Patrol uses your location to display it on the patrol zone map."
      }
    },
    "android": {
      "package": "com.btp.patrol",
      "adaptiveIcon": {
        "backgroundColor": "#0D1B3E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D1B3E",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "BTP Patrol uses your location to show it on the patrol zone map."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FFB300"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "BTP Patrol needs camera access to capture GPS-stamped patrol photos.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
